# Notion API
NOTION_SECRET=your_notion_integration_secret
NOTION_EXERCISE_DB=your_exercise_library_database_id
NOTION_PROGRAMS_DB=your_training_programs_database_id
NOTION_ENTRIES_DB=your_workout_entries_database_id
# Create a new Notion DB with: Name (title), Program (relation), Completed At (date),
# Duration (min) (number), Sets Completed (number), Total Sets (number),
# Notes (rich text), PRs (rich text)
NOTION_LOGS_DB=your_workout_logs_database_id

# Admin
ADMIN_PASSWORD=your_admin_password

# Giphy — used by /api/giphy/sync to auto-fill exercise videos
# from the DocGarrett channel (https://giphy.com/channel/DocGarrett)
# Get a free key at https://developers.giphy.com/dashboard
GIPHY_API_KEY=your_giphy_api_key

# App
NEXT_PUBLIC_APP_NAME=BeInShapeAnywhere
